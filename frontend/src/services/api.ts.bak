import axios from 'axios';

const API_URL = 'https://31.130.155.16:8443/api';

const api = axios.create({
  baseURL: API_URL,
  headers: {
    'Content-Type': 'application/json',
  },
});

// Перехватчик для добавления токена авторизации
api.interceptors.request.use(
  (config) => {
    const token = localStorage.getItem('token');
    if (token) {
      config.headers.Authorization = `Bearer ${token}`;
    }
    return config;
  },
  (error) => {
    return Promise.reject(error);
  }
);

// Перехватчик для обработки ошибок
api.interceptors.response.use(
  (response) => response,
  (error) => {
    if (error.response?.status === 401) {
      localStorage.removeItem('token');
      localStorage.removeItem('user');
      window.location.href = '/login';
    }
    return Promise.reject(error);
  }
);

// ===== Авторизация =====
export const auth = {
  login: (login: string, password: string) =>
    api.post('/auth/login', { login, password }),
  getMe: () =>
    api.get('/auth/me'),
};

// ===== Сотрудник =====
export const employee = {
  getData: () =>
    api.get('/employee/data'),
};

// ===== FAQ =====
export const faq = {
  search: (query: string) =>
    api.get(`/faq/search?query=${encodeURIComponent(query)}`),
  getCategories: () =>
    api.get('/faq/categories'),
};

// ===== Документы =====
export const documents = {
  getCategories: () =>
    api.get('/documents/categories'),
  getByCategory: (category: string) =>
    api.get(`/documents/category/${encodeURIComponent(category)}`),
  download: (id: number) =>
    api.get(`/documents/download/${id}`, { responseType: 'blob' }),
};

// ===== Админка: FAQ =====
export const adminFaq = {
  getAll: () =>
    api.get('/admin/faq'),
  getById: (id: number) =>
    api.get(`/admin/faq/${id}`),
  getRoot: () =>
    api.get('/admin/faq/root'),
  getChildren: (id: number) =>
    api.get(`/admin/faq/${id}/children`),
  create: (data: FormData) =>
    api.post('/admin/faq', data, {
      headers: { 'Content-Type': 'multipart/form-data' }
    }),
  update: (id: number, data: FormData) =>
    api.put(`/admin/faq/${id}`, data, {
      headers: { 'Content-Type': 'multipart/form-data' }
    }),
  delete: (id: number) =>
    api.delete(`/admin/faq/${id}`),
};

// ===== Админка: Пользователи =====
export const adminUsers = {
  getAll: () =>
    api.get('/admin/users'),
  getById: (id: number) =>
    api.get(`/admin/users/${id}`),
  create: (data: any) =>
    api.post('/admin/users', data),
  update: (id: number, data: any) =>
    api.put(`/admin/users/${id}`, data),
  delete: (id: number) =>
    api.delete(`/admin/users/${id}`),
  resetPassword: (id: number, newPassword: string) =>
    api.post(`/admin/users/${id}/reset-password`, { newPassword }),
};

// ===== Статистика =====
export const stats = {
  getAdminStats: () =>
    api.get('/stats/admin'),
  saveChat: (message: string, bot_response: string) =>
    api.post('/stats/chat/save', { message, bot_response }),
};

// ===== Организации =====
export const organizations = {
  getAll: () =>
    api.get('/organizations'),
  getById: (id: number) =>
    api.get(`/organizations/${id}`),
  create: (name: string) =>
    api.post('/organizations', { name }),
  update: (id: number, name: string) =>
    api.put(`/organizations/${id}`, { name }),
  delete: (id: number) =>
    api.delete(`/organizations/${id}`),
};

// ===== Профиль =====
export const profile = {
  get: () =>
    api.get('/profile'),
  update: (data: { department?: string | null; organization_id?: number | null }) =>
    api.put('/profile', data),
};

// ===== Чат =====
export const chat = {
  resetDialog: () =>
    api.post('/faq/reset'),
};

export default api;
