import React, { useEffect, useState } from 'react';
import { adminFaq } from '../services/api';
import './AdminFaq.css';

interface FaqItem {
  id: number;
  keywords: string;
  question: string | null;
  answer: string;
  category: string | null;
  file_path: string | null;
  created_at: string;
}

const AdminFaq: React.FC = () => {
  const [items, setItems] = useState<FaqItem[]>([]);
  const [loading, setLoading] = useState(true);
  const [showForm, setShowForm] = useState(false);
  const [editingItem, setEditingItem] = useState<FaqItem | null>(null);
  const [formData, setFormData] = useState({
    keywords: '',
    question: '',
    answer: '',
    category: '',
  });
  const [file, setFile] = useState<File | null>(null);

  useEffect(() => {
    loadItems();
  }, []);

  const loadItems = async () => {
    try {
      const response = await adminFaq.getAll();
      setItems(response.data);
    } catch (error) {
      console.error('Error loading FAQ:', error);
    } finally {
      setLoading(false);
    }
  };

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    
    const formDataToSend = new FormData();
    formDataToSend.append('keywords', formData.keywords);
    formDataToSend.append('question', formData.question);
    formDataToSend.append('answer', formData.answer);
    formDataToSend.append('category', formData.category);
    if (file) {
      formDataToSend.append('file', file);
    }

    try {
      if (editingItem) {
        await adminFaq.update(editingItem.id, formDataToSend);
      } else {
        await adminFaq.create(formDataToSend);
      }
      
      resetForm();
      loadItems();
    } catch (error) {
      console.error('Error saving FAQ:', error);
    }
  };

  const handleEdit = (item: FaqItem) => {
    setEditingItem(item);
    setFormData({
      keywords: item.keywords,
      question: item.question || '',
      answer: item.answer,
      category: item.category || '',
    });
    setShowForm(true);
  };

  const handleDelete = async (id: number) => {
    if (window.confirm('Удалить запись?')) {
      try {
        await adminFaq.delete(id);
        loadItems();
      } catch (error) {
        console.error('Error deleting FAQ:', error);
      }
    }
  };

  const resetForm = () => {
    setShowForm(false);
    setEditingItem(null);
    setFormData({ keywords: '', question: '', answer: '', category: '' });
    setFile(null);
  };

  if (loading) return <div className="loading">Загрузка...</div>;

  return (
    <div className="admin-faq">
      <div className="faq-header">
        <h1>Управление базой знаний</h1>
        <button className="add-button" onClick={() => setShowForm(true)}>
          + Добавить запись
        </button>
      </div>

      {showForm && (
        <div className="modal">
          <div className="modal-content">
            <h2>{editingItem ? 'Редактировать' : 'Новая запись'}</h2>
            <form onSubmit={handleSubmit}>
              <div className="form-group">
                <label>Ключевые слова *</label>
                <input
                  type="text"
                  value={formData.keywords}
                  onChange={(e) => setFormData({...formData, keywords: e.target.value})}
                  placeholder="отпуск, отдых, отгул"
                  required
                />
              </div>

              <div className="form-group">
                <label>Вопрос</label>
                <input
                  type="text"
                  value={formData.question}
                  onChange={(e) => setFormData({...formData, question: e.target.value})}
                  placeholder="Как оформить отпуск?"
                />
              </div>

              <div className="form-group">
                <label>Ответ *</label>
                <textarea
                  value={formData.answer}
                  onChange={(e) => setFormData({...formData, answer: e.target.value})}
                  rows={5}
                  required
                />
              </div>

              <div className="form-group">
                <label>Категория</label>
                <input
                  type="text"
                  value={formData.category}
                  onChange={(e) => setFormData({...formData, category: e.target.value})}
                  placeholder="Отпуск"
                />
              </div>

              <div className="form-group">
                <label>Файл</label>
                <input
                  type="file"
                  onChange={(e) => setFile(e.target.files?.[0] || null)}
                />
              </div>

              <div className="form-actions">
                <button type="submit" className="save-button">
                  {editingItem ? 'Сохранить' : 'Создать'}
                </button>
                <button type="button" className="cancel-button" onClick={resetForm}>
                  Отмена
                </button>
              </div>
            </form>
          </div>
        </div>
      )}

      <table className="faq-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Ключевые слова</th>
            <th>Вопрос</th>
            <th>Ответ</th>
            <th>Категория</th>
            <th>Файл</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          {items.map(item => (
            <tr key={item.id}>
              <td>{item.id}</td>
              <td>{item.keywords}</td>
              <td>{item.question}</td>
              <td>{item.answer.substring(0, 50)}...</td>
              <td>{item.category}</td>
              <td>{item.file_path ? '📎' : '-'}</td>
              <td className="actions">
                <button onClick={() => handleEdit(item)} className="edit-btn">✏️</button>
                <button onClick={() => handleDelete(item.id)} className="delete-btn">🗑️</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
};

export default AdminFaq;
